<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:gravity="center" android:orientation="vertical" android:focusable="false"
    android:clipChildren="false" android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:focusable="false"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/px_300">
        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_44"
            android:textColor="@color/white" android:gravity="center" android:id="@id/cache"
            android:focusable="false" android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <com.bilibili.tv.widget.DrawFrameLayout android:id="@id/clean"
            android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
            android:focusable="true" android:nextFocusLeft="@id/clean"
            android:nextFocusRight="@id/clean" android:nextFocusUp="@id/clean"
            android:nextFocusDown="@id/image_size_hd" android:layout_width="@dimen/px_330"
            android:layout_height="@dimen/px_96" android:layout_marginTop="@dimen/px_100">
            <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_44"
                android:textColor="@color/white" android:gravity="center"
                android:layout_gravity="center" android:focusable="false"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="点击清除" />
        </com.bilibili.tv.widget.DrawFrameLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:focusable="false"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/px_200">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:focusable="false"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="@dimen/px_250">
            <com.bilibili.tv.widget.ShadowTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图片大小："
                android:textColor="@color/white"
                android:textSize="@dimen/px_44"
                android:layout_marginLeft="@dimen/px_30"
                android:layout_marginRight="@dimen/px_30" />
            <com.bilibili.tv.widget.DrawFrameLayout
                android:id="@id/image_size_hd"
                android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusRight="@id/image_size_thumbnail"
                android:nextFocusDown="@id/cache_limit_50"
                android:paddingLeft="@dimen/px_30"
                android:paddingRight="@dimen/px_30"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/px_96">
                <com.bilibili.tv.widget.ShadowTextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:focusable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="高清图"
                    android:textColor="@color/white"
                    android:textSize="@dimen/px_44" />
            </com.bilibili.tv.widget.DrawFrameLayout>
            <com.bilibili.tv.widget.DrawFrameLayout
                android:id="@id/image_size_thumbnail"
                android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusLeft="@id/image_size_hd"
                android:nextFocusRight="@id/image_size_thumbnail"
                android:nextFocusDown="@id/cache_limit_300"
                android:paddingLeft="@dimen/px_30"
                android:paddingRight="@dimen/px_30"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/px_96"
                android:layout_marginLeft="@dimen/px_40">
                <com.bilibili.tv.widget.ShadowTextView
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:focusable="false"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="缩略图"
                    android:textColor="@color/white"
                    android:textSize="@dimen/px_44" />
            </com.bilibili.tv.widget.DrawFrameLayout>
        </LinearLayout>
        <com.bilibili.tv.widget.ShadowTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="* 高清图可能会影响图片加载速度，增加缓存占用"
            android:textColor="@color/white"
            android:textSize="@dimen/px_28"
            android:layout_marginTop="@dimen/px_20" />
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:focusable="false"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="@dimen/px_200">
        <com.bilibili.tv.widget.ShadowTextView
            android:gravity="center"
            android:layout_gravity="center"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="缓存上限："
            android:textColor="@color/white"
            android:textSize="@dimen/px_44"
            android:layout_marginLeft="@dimen/px_30"
            android:layout_marginRight="@dimen/px_30" />
        <com.bilibili.tv.widget.DrawFrameLayout
            android:id="@id/cache_limit_50"
            android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/cache_limit_100"
            android:nextFocusUp="@id/image_size_hd"
            android:paddingLeft="@dimen/px_30"
            android:paddingRight="@dimen/px_30"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/px_96">
            <com.bilibili.tv.widget.ShadowTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50M"
                android:textColor="@color/white"
                android:textSize="@dimen/px_44" />
        </com.bilibili.tv.widget.DrawFrameLayout>
        <com.bilibili.tv.widget.DrawFrameLayout
            android:id="@id/cache_limit_100"
            android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/cache_limit_50"
            android:nextFocusRight="@id/cache_limit_300"
            android:nextFocusUp="@id/image_size_hd"
            android:paddingLeft="@dimen/px_30"
            android:paddingRight="@dimen/px_30"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/px_96"
            android:layout_marginLeft="@dimen/px_40">
            <com.bilibili.tv.widget.ShadowTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100M"
                android:textColor="@color/white"
                android:textSize="@dimen/px_44" />
        </com.bilibili.tv.widget.DrawFrameLayout>
        <com.bilibili.tv.widget.DrawFrameLayout
            android:id="@id/cache_limit_300"
            android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/cache_limit_100"
            android:nextFocusRight="@id/cache_limit_500"
            android:nextFocusUp="@id/image_size_thumbnail"
            android:paddingLeft="@dimen/px_30"
            android:paddingRight="@dimen/px_30"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/px_96"
            android:layout_marginLeft="@dimen/px_40">
            <com.bilibili.tv.widget.ShadowTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="300M"
                android:textColor="@color/white"
                android:textSize="@dimen/px_44" />
        </com.bilibili.tv.widget.DrawFrameLayout>
        <com.bilibili.tv.widget.DrawFrameLayout
            android:id="@id/cache_limit_500"
            android:background="@drawable/shape_rectangle_trans_with_12corner_white_10"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/cache_limit_300"
            android:nextFocusRight="@id/cache_limit_500"
            android:nextFocusUp="@id/image_size_thumbnail"
            android:paddingLeft="@dimen/px_30"
            android:paddingRight="@dimen/px_30"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/px_96"
            android:layout_marginLeft="@dimen/px_40">
            <com.bilibili.tv.widget.ShadowTextView
                android:gravity="center"
                android:layout_gravity="center"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500M"
                android:textColor="@color/white"
                android:textSize="@dimen/px_44" />
        </com.bilibili.tv.widget.DrawFrameLayout>
    </LinearLayout>
</LinearLayout>