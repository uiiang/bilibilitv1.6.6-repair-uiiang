<?xml version="1.0" encoding="utf-8"?>
<com.bilibili.tv.widget.DrawRelativeLayout
  android:id="@id/draw"
  android:padding="@dimen/px_20"
  android:focusable="true"
  android:focusableInTouchMode="true"
  android:clickable="true"
  android:layout_width="match_parent" 
  android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">
  <FrameLayout android:id="@id/img_layout" android:focusable="false"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:layout_centerVertical="true">
    <com.bilibili.tv.widget.ScalableImageView android:id="@id/img"
      android:background="@drawable/shape_default_loading_img" android:focusable="false"
      android:layout_width="@dimen/px_375" android:layout_height="@dimen/px_240"
      app:placeholderImage="@drawable/default_img_loading"
      app:placeholderImageScaleType="centerInside" app:roundedCornerRadius="@dimen/px_12" />
    <ImageView android:id="@id/tag" android:focusable="false" android:layout_width="@dimen/px_60"
      android:layout_height="@dimen/px_60" />
    <TextView android:textSize="@dimen/px_40" android:textColor="@color/white"
      android:gravity="center" android:id="@id/tag_text" android:focusable="false"
      android:layout_width="@dimen/px_60" android:layout_height="@dimen/px_60" />
  </FrameLayout>
  <LinearLayout android:id="@+id/bottom_info" android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_toRightOf="@id/img_layout" android:layout_marginLeft="@dimen/px_20"
    android:orientation="vertical" android:layout_alignBottom="@id/img_layout">
    <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
      android:textColor="@color/white_50" android:gravity="center_vertical"
      android:id="@id/up"
      android:focusable="false" android:duplicateParentState="true"
      android:layout_width="wrap_content" android:layout_height="wrap_content"
      android:maxLines="1" android:singleLine="true"
      android:drawablePadding="@dimen/px_8" />
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
      android:orientation="horizontal" android:layout_marginTop="@dimen/px_6">
      <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
        android:textColor="@color/white_50" android:gravity="center_vertical" android:id="@id/play"
        android:focusable="false" android:duplicateParentState="true"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:maxLines="1"
        android:drawablePadding="@dimen/px_8" />
      <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
        android:textColor="@color/white_50" android:gravity="center_vertical"
        android:id="@id/danmaku"
        android:focusable="false" android:duplicateParentState="true"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/px_30" android:maxLines="1"
        android:drawablePadding="@dimen/px_8" />
    </LinearLayout>
  </LinearLayout>
  <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_36"
    android:textColor="@color/white" android:id="@id/title" android:focusable="false"
    android:duplicateParentState="true" android:layout_width="wrap_content"
    android:layout_height="wrap_content" android:maxLines="3"
    android:layout_toRightOf="@id/img_layout" android:layout_marginLeft="@dimen/px_20"
    android:layout_alignTop="@id/img_layout"
    android:layout_above="@id/bottom_info"
    android:layout_marginBottom="@dimen/px_10" />
</com.bilibili.tv.widget.DrawRelativeLayout>
