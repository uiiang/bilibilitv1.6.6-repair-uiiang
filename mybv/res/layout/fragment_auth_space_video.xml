<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/background_image"
    android:focusable="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header 区域：固定在顶部 -->
    <LinearLayout
        android:id="@id/space_header_layout"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/px_50"
        android:layout_marginTop="@dimen/px_50"
        android:layout_marginRight="@dimen/px_50"
        android:focusable="false">

        <com.bilibili.tv.widget.ShadowTextView
            android:id="@id/header_title"
            android:textSize="@dimen/px_48"
            android:textColor="@color/white"
            android:ellipsize="middle"
            android:maxEms="15"
            android:singleLine="true"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <FrameLayout
            android:id="@id/video_detail_up_layout"
            android:padding="@dimen/px_16"
            android:focusable="false"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.bilibili.tv.widget.DrawTextView
                android:id="@id/attention"
                android:textSize="@dimen/px_32"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:background="@drawable/background_white_rect"
                android:paddingLeft="@dimen/px_18"
                android:paddingTop="@dimen/px_5"
                android:paddingRight="@dimen/px_18"
                android:paddingBottom="@dimen/px_5"
                android:focusable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="＋关注" />
        </FrameLayout>

        <com.bilibili.tv.widget.ShadowTextView
            android:id="@id/header_count"
            android:textSize="@dimen/px_32"
            android:textColor="@color/white_50"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/px_24" />

        <Space
            android:focusable="false"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <com.bilibili.tv.widget.ShadowTextView
            android:id="@id/hint_sort"
            android:textSize="@dimen/px_36"
            android:textColor="@color/focus_text_color_white_50"
            android:focusable="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="长按[OK]键排序" />
    </LinearLayout>

    <!-- 视频列表 -->
    <android.support.v7.widget.RecyclerView
        android:id="@id/recycler_view"
        android:focusable="false"
        android:scrollbars="none"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/px_10" />
</LinearLayout>
