<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:id="@id/video_detail_layout" android:background="@drawable/background_image"
    android:focusable="false" android:layout_width="fill_parent" android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.bilibili.tv.widget.ScalableImageView android:id="@id/blur"
        android:layout_width="fill_parent" android:layout_height="fill_parent" />
    <View android:background="@color/black_60" android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout android:orientation="vertical" android:id="@id/content_layout"
        android:focusable="false" android:visibility="gone" android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <LinearLayout android:orientation="horizontal" android:paddingLeft="@dimen/px_50"
            android:focusable="false"
            android:clipChildren="false" android:clipToPadding="false"
            android:layout_width="fill_parent" android:layout_height="@dimen/px_396"
            android:layout_marginTop="@dimen/px_50">
            <com.bilibili.tv.widget.ScalableImageView android:id="@id/video_detail_cover"
                android:focusable="false" android:layout_width="@dimen/px_600"
                android:layout_height="@dimen/px_400"
                app:placeholderImage="@drawable/bili_default_image_tv"
                app:placeholderImageScaleType="centerInside" app:roundedCornerRadius="@dimen/px_12" />
            <LinearLayout android:orientation="vertical" android:focusable="false"
                android:clipChildren="false" android:clipToPadding="false"
                android:layout_width="0.0dip" android:layout_height="fill_parent"
                android:layout_weight="1.0" android:layout_marginLeft="@dimen/px_50"
                android:layout_marginRight="@dimen/px_70">
                <!-- 第一部分：标题 -->
                <LinearLayout android:gravity="top" android:focusable="false"
                    android:clipChildren="false" android:clipToPadding="false"
                    android:layout_width="fill_parent" android:layout_height="0.0dip"
                    android:layout_weight="1.0">
                    <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_36"
                        android:textColor="@color/white" android:ellipsize="end"
                        android:id="@id/video_detail_title" android:focusable="false"
                        android:layout_width="fill_parent" android:layout_height="wrap_content"
                        android:maxLines="3" />
                </LinearLayout>
                <!-- 第二部分：播放数量、弹幕数量、时长、投稿时间、up主名字 -->
                <LinearLayout android:orientation="vertical" android:focusable="false"
                    android:clipChildren="true" android:clipToPadding="false"
                    android:layout_width="fill_parent" android:layout_height="0.0dip"
                    android:layout_weight="1.0">
                    <!-- 播放数量和弹幕数量 -->
                    <LinearLayout android:gravity="center" android:id="@id/video_stats"
                        android:focusable="false" android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_width="fill_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/px_15">
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/video_detail_play_count" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white"
                            android:id="@id/video_detail_play_count"
                            android:focusable="false" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10"
                            android:layout_marginRight="@dimen/px_60" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/video_detail_danmaku" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white" android:id="@id/video_detail_danmaku"
                            android:focusable="false" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10"
                            android:layout_marginRight="@dimen/px_30" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="时长:" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white" android:id="@id/video_detail_duration"
                            android:focusable="false" android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10"
                            android:layout_marginRight="@dimen/px_30" android:layout_weight="0.7" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/video_detail_uptime" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white" android:id="@id/video_detail_uptime"
                            android:focusable="false" android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10"
                            android:layout_marginRight="@dimen/px_30" android:layout_weight="1.0" />
                    </LinearLayout>
                    <!-- up主名字 -->
                    <LinearLayout android:gravity="center" android:id="@id/video_uper_container"
                        android:focusable="false" android:clipChildren="true"
                        android:clipToPadding="false"
                        android:layout_width="fill_parent" android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/video_detail_uper" />
                        <HorizontalScrollView android:id="@id/video_detail_up_layout"
                            android:focusable="false"
                            android:scrollbars="none"
                            android:clipChildren="true" android:clipToPadding="false"
                            android:layout_width="0.0dip" android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10" android:layout_weight="1.0"
                            android:paddingRight="@dimen/px_20">
                            <LinearLayout android:id="@+id/video_detail_staff_container"
                                android:orientation="horizontal"
                                android:focusable="false"
                                android:clipChildren="false" android:clipToPadding="false"
                                android:layout_width="wrap_content" android:layout_height="wrap_content">
                            </LinearLayout>
                        </HorizontalScrollView>
                    </LinearLayout>
                </LinearLayout>
                <!-- 第三部分：播放进度显示区域 -->
                <LinearLayout android:focusable="false"
                    android:gravity="center_vertical"
                    android:paddingBottom="@dimen/px_10"
                    android:clipChildren="false" android:clipToPadding="false"
                    android:layout_width="fill_parent" android:layout_height="wrap_content">
                    <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/video_history_play_btn_layout"
                        android:background="@drawable/background_white_rect"
                        android:focusable="true" android:focusableInTouchMode="true"
                        android:nextFocusLeft="@id/video_history_play_btn_layout"
                        android:nextFocusRight="@id/video_re_play_btn_layout"
                        android:clipToPadding="false"
                        android:layout_width="wrap_content" android:minWidth="@dimen/px_100"
                        android:layout_height="@dimen/px_80">
                        <ImageView android:id="@+id/video_history_play_img"
                            android:focusable="false"
                            android:background="@drawable/ic_play_arrow_white_48dp"
                            android:layout_width="@dimen/px_48"
                            android:layout_height="@dimen/px_48"
                            android:layout_marginLeft="@dimen/px_20"
                            android:layout_marginRight="@dimen/px_20"
                            android:scaleType="fitCenter" />
                        <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                            android:textColor="@color/white" android:gravity="center"
                            android:id="@+id/video_history_play_btn" android:focusable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginRight="@dimen/px_26" />
                    </com.bilibili.tv.widget.DrawLinearLayout>
                    <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/video_no_history_play_btn_layout"
                        android:background="@drawable/background_white_rect"
                        android:focusable="true" android:focusableInTouchMode="true"
                        android:visibility="gone"
                        android:nextFocusLeft="@id/video_history_play_btn_layout"
                        android:nextFocusRight="@id/video_re_play_btn_layout"
                        android:clipToPadding="false"
                        android:layout_width="wrap_content" android:minWidth="@dimen/px_100"
                        android:layout_height="@dimen/px_80"
                        android:layout_marginLeft="@dimen/px_10">
                        <CheckBox android:id="@+id/video_no_history_play_checkbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_20"
                            android:layout_marginRight="@dimen/px_10"
                            android:scaleX="1.3"
                            android:scaleY="1.3"
                            android:focusable="false" />
                        <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                            android:textColor="@color/white" android:gravity="center"
                            android:id="@+id/video_no_history_play_btn" android:focusable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginRight="@dimen/px_26" />
                    </com.bilibili.tv.widget.DrawLinearLayout>
                    <LinearLayout android:id="@+id/video_history_container"
                        android:visibility="visible" android:focusable="false"
                        android:gravity="center_vertical"
                        android:layout_marginLeft="@dimen/px_10"
                        android:clipChildren="false" android:clipToPadding="false"
                        android:layout_width="fill_parent" android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:id="@+id/video_re_play_btn_layout"
                            android:background="@drawable/background_white_rect"
                            android:focusable="true" android:focusableInTouchMode="true"
                            android:nextFocusLeft="@id/video_history_play_btn_layout"
                            android:nextFocusRight="@id/video_re_play_btn_layout"
                            android:clipToPadding="false"
                            android:layout_width="wrap_content" android:minWidth="@dimen/px_100"
                            android:layout_height="@dimen/px_80">
                            <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                                android:textColor="@color/white" android:gravity="center"
                                android:id="@+id/video_re_play_btn" android:focusable="false"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="@dimen/px_20"
                                android:layout_marginRight="@dimen/px_20" />
                        </com.bilibili.tv.widget.DrawLinearLayout>
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white_50" android:focusable="false"
                            android:id="@+id/video_history_label"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_20"
                            android:text="上次播放到" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white" android:id="@+id/video_history_title"
                            android:focusable="false" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10"
                            android:maxLines="1" android:maxEms="8" android:ellipsize="middle" />
                        <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                            android:textColor="@color/white"
                            android:id="@+id/video_history_progress"
                            android:focusable="false" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="@dimen/px_10" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollView"
            android:paddingTop="@dimen/px_24"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_36"
                    android:textColor="@color/white" android:id="@id/video_detail_ep_title"
                    android:paddingLeft="@dimen/px_70" android:focusable="false"
                    android:visibility="gone" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <android.support.v7.widget.RecyclerView android:id="@id/video_detail_ep_layout"
                    android:paddingLeft="@dimen/px_50" android:paddingTop="@dimen/px_24"
                    android:paddingRight="@dimen/px_70" android:focusable="true"
                    android:nextFocusUp="@id/video_detail_coin"
                    android:nextFocusDown="@+id/video_detail_seasons_container"
                    android:nextFocusLeft="@id/video_detail_ep_layout"
                    android:nextFocusRight="@id/video_detail_ep_layout"
                    android:visibility="gone" android:clipChildren="false"
                    android:clipToPadding="false" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <LinearLayout
                    android:id="@+id/video_detail_seasons_container"
                    android:orientation="vertical"
                    android:focusable="false"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_36"
                    android:textColor="@color/white" android:id="@id/video_detail_episodes_title"
                    android:paddingLeft="@dimen/px_70" android:focusable="false"
                    android:visibility="gone" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="@dimen/px_16"
                    android:text="视频选集" />
                <android.support.v7.widget.RecyclerView android:id="@id/video_detail_episodes_video"
                    android:paddingLeft="@dimen/px_50" android:paddingTop="@dimen/px_24"
                    android:paddingRight="@dimen/px_70" android:paddingBottom="@dimen/px_24"
                    android:focusable="true"
                    android:nextFocusUp="@id/video_detail_coin"
                    android:nextFocusLeft="@id/video_detail_episodes_video"
                    android:nextFocusRight="@id/video_detail_episodes_video"
                    android:visibility="gone" android:clipChildren="false"
                    android:clipToPadding="false" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_36"
                    android:textColor="@color/white" android:id="@id/video_detail_relate_title"
                    android:paddingLeft="@dimen/px_70" android:focusable="false"
                    android:visibility="gone" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="@dimen/px_16"
                    android:text="相关视频" />
                <android.support.v7.widget.RecyclerView android:id="@id/video_detail_relate_video"
                    android:paddingLeft="@dimen/px_50" android:paddingTop="@dimen/px_24"
                    android:paddingRight="@dimen/px_70" android:paddingBottom="@dimen/px_24"
                    android:focusable="true"
                    android:nextFocusUp="@id/video_detail_coin"
                    android:nextFocusLeft="@id/video_detail_relate_video"
                    android:nextFocusRight="@id/video_detail_relate_video"
                    android:visibility="gone" android:clipChildren="false"
                    android:clipToPadding="false" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <LinearLayout android:gravity="center_vertical"
                    android:id="@id/video_detail_des_layout"
                    android:paddingLeft="@dimen/px_60" android:paddingRight="@dimen/px_70"
                    android:focusable="false" android:layout_width="fill_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="@dimen/px_8"
                    android:paddingBottom="@dimen/px_24">
                    <com.bilibili.tv.widget.ShadowTextView android:textSize="@dimen/px_32"
                        android:textColor="@color/white_50" android:focusable="false"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/video_detail_tag" />
                    <android.support.v7.widget.RecyclerView android:id="@id/flow_tag_view"
                        android:focusable="true"
                        android:nextFocusUp="@id/video_detail_coin"
                        android:layout_width="fill_parent" android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/px_10" />
                </LinearLayout>

                <LinearLayout android:gravity="center_vertical" android:id="@id/video_controller"
                    android:paddingLeft="@dimen/px_50" android:paddingRight="@dimen/px_70"
                    android:focusable="false" android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/px_16"
                    android:layout_marginBottom="@dimen/px_100">
                    <LinearLayout android:padding="@dimen/px_20" android:clipChildren="false"
                        android:clipToPadding="false" android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                            android:orientation="horizontal" android:id="@id/video_detail_like"
                            android:background="@drawable/background_white_rect"
                            android:focusable="true" android:focusableInTouchMode="true"
                            android:nextFocusLeft="@id/video_detail_like"
                            android:nextFocusRight="@id/video_detail_coin"
                            android:nextFocusUp="@id/flow_tag_view"
                            android:nextFocusDown="@id/video_detail_like"
                            android:clipToPadding="false"
                            android:layout_width="wrap_content" android:minWidth="@dimen/px_120"
                            android:layout_height="@dimen/px_80">
                            <ImageView android:id="@id/video_detail_like_img"
                                android:background="@drawable/ic_like"
                                android:layout_width="@dimen/px_44"
                                android:layout_height="@dimen/px_44"
                                android:layout_marginLeft="@dimen/px_36"
                                android:layout_marginRight="@dimen/px_36"
                                android:scaleType="fitCenter" />
                            <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                                android:textColor="@color/white" android:gravity="center"
                                android:id="@id/video_detail_like_text" android:focusable="false"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginRight="@dimen/px_36" android:text="点赞" />
                        </com.bilibili.tv.widget.DrawLinearLayout>
                    </LinearLayout>
                    <LinearLayout android:padding="@dimen/px_20" android:clipChildren="false"
                        android:clipToPadding="false" android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                            android:orientation="horizontal" android:id="@id/video_detail_coin"
                            android:background="@drawable/background_white_rect"
                            android:focusable="true" android:focusableInTouchMode="true"
                            android:nextFocusLeft="@id/video_detail_like"
                            android:nextFocusRight="@id/video_detail_favorite"
                            android:nextFocusUp="@id/flow_tag_view"
                            android:nextFocusDown="@id/video_detail_coin"
                            android:clipToPadding="false"
                            android:layout_width="wrap_content" android:minWidth="@dimen/px_120"
                            android:layout_height="@dimen/px_80">
                            <ImageView android:id="@id/video_detail_coin_img"
                                android:background="@drawable/ic_coin"
                                android:layout_width="@dimen/px_44"
                                android:layout_height="@dimen/px_44"
                                android:layout_marginLeft="@dimen/px_36"
                                android:layout_marginRight="@dimen/px_36"
                                android:scaleType="fitCenter" />
                            <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                                android:textColor="@color/white" android:gravity="center"
                                android:id="@id/video_detail_coin_text" android:focusable="false"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginRight="@dimen/px_36" android:text="投币" />
                        </com.bilibili.tv.widget.DrawLinearLayout>
                    </LinearLayout>
                    <LinearLayout android:padding="@dimen/px_20" android:clipChildren="false"
                        android:clipToPadding="false" android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                            android:orientation="horizontal" android:id="@id/video_detail_favorite"
                            android:background="@drawable/background_white_rect"
                            android:focusable="true" android:focusableInTouchMode="true"
                            android:nextFocusLeft="@id/video_detail_coin"
                            android:nextFocusRight="@id/video_detail_watch_later"
                            android:nextFocusUp="@id/flow_tag_view"
                            android:nextFocusDown="@id/video_detail_favorite"
                            android:clipToPadding="false"
                            android:layout_width="wrap_content" android:minWidth="@dimen/px_120"
                            android:layout_height="@dimen/px_80">
                            <ImageView android:id="@id/video_detail_favorite_img"
                                android:background="@drawable/ic_favorite"
                                android:layout_width="@dimen/px_44"
                                android:layout_height="@dimen/px_44"
                                android:layout_marginLeft="@dimen/px_36"
                                android:layout_marginRight="@dimen/px_36"
                                android:scaleType="fitCenter" />
                            <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                                android:textColor="@color/white" android:gravity="center"
                                android:id="@id/video_detail_favorite_text"
                                android:focusable="false"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginRight="@dimen/px_36" android:text="收藏" />
                        </com.bilibili.tv.widget.DrawLinearLayout>
                    </LinearLayout>
                    <LinearLayout android:padding="@dimen/px_20" android:clipChildren="false"
                        android:clipToPadding="false" android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.bilibili.tv.widget.DrawLinearLayout android:gravity="center_vertical"
                            android:orientation="horizontal" android:id="@id/video_detail_watch_later"
                            android:background="@drawable/background_white_rect"
                            android:focusable="true" android:focusableInTouchMode="true"
                            android:nextFocusLeft="@id/video_detail_favorite"
                            android:nextFocusRight="@id/video_detail_watch_later"
                            android:nextFocusUp="@id/flow_tag_view"
                            android:nextFocusDown="@id/video_detail_watch_later"
                            android:clipToPadding="false"
                            android:layout_width="wrap_content" android:minWidth="@dimen/px_120"
                            android:layout_height="@dimen/px_80">
                            <ImageView android:id="@id/video_detail_watch_later_img"
                                android:background="@drawable/ic_hourglass_empty_white_48dp"
                                android:layout_width="@dimen/px_44"
                                android:layout_height="@dimen/px_44"
                                android:layout_marginLeft="@dimen/px_36"
                                android:layout_marginRight="@dimen/px_36"
                                android:scaleType="fitCenter" />
                            <com.bilibili.tv.widget.DrawTextView android:textSize="@dimen/px_36"
                                android:textColor="@color/white" android:gravity="center"
                                android:id="@id/video_detail_watch_later_text"
                                android:focusable="false"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginRight="@dimen/px_36" android:text="稍后再看" />
                        </com.bilibili.tv.widget.DrawLinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>